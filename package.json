{
  "name": "wle-ui-package",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build:js": "tsup",
    "build:css": "npx @tailwindcss/cli -i ./src/globals.css -o ./dist/index.css --minify",
    "build": "npm run build:js && npm run build:css",
    "dev:js": "tsup --watch",
    "dev:css": "npx @tailwindcss/cli -i ./src/globals.css -o ./dist/index.css --watch",
    "dev": "npm run dev:js & npm run dev:css"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./style.css": "./dist/index.css"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "dependencies": {
    "react-router": "^7.15.1",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.6.0",
    "wle-core": "github:lucieno-zandry/wle-core-package"
  }
}